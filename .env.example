# ==========================================================
# Tackle Assist (タックルアシスト) 環境変数ファイル
# 
# 使い方:
# 1. このファイルをコピーして `.env` という名前に変更します
# 2. 以下の値にご自身の取得したAPIキーやURLを設定してください
# ==========================================================

# 1. Neon Database 接続用 URL
# Neonダッシュボード (neon.tech) より取得したDATABASE_URLを貼り付けます
EXPO_PUBLIC_DATABASE_URL="postgresql://user:password@hostname.neon.tech/neondb?sslmode=require"

# 2. Google Gemini API キー
# Google AI Studio (aistudio.google.com) より取得したAPIキーを貼り付けます
EXPO_PUBLIC_GEMINI_API_KEY="AIzaSyYourGeneratedGeminiApiKeyHere"

# ==========================================================
# ※ 注意: 今回はMVP構築のため、 Expo サーバーレス(API Routes)またはフロントから
# 安全に呼び出すテスト目的で直接環境変数に格納します。
# 将来的な本番公開時は必ずバックエンド専用のシークレット管理へ移動します。
